# Slack
SLACK_SIGNING_SECRET=your_slack_signing_secret_here
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_BOT_USER_ID=
BACKFILL_DAYS=30
SLACK_PAGE_SIZE=200
BACKFILL_MAX_PAGES=100

# Database — direct connection (required for pg-boss LISTEN/NOTIFY)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Database — pooled connection (optional, for application queries via pgbouncer)
DATABASE_URL_POOLED=postgresql://user:password@host:6543/dbname?pgbouncer=true

# Supabase client (optional)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Server
PORT=3000
LOG_LEVEL=info
NODE_ENV=development

# API Authentication (required in production)
API_AUTH_TOKEN=

# CORS (required in production)
CORS_ORIGIN=*

# Proxy & Timeouts
TRUST_PROXY=false
REQUEST_TIMEOUT_MS=30000
SHUTDOWN_TIMEOUT_MS=15000
HEALTHCHECK_DB_TIMEOUT_MS=3000

# LLM Provider — pick one: openai | gemini
# Models auto-default per provider if not set:
#   openai  → gpt-4o-mini / gpt-4o
#   gemini  → gemini-2.0-flash / gemini-2.5-pro
LLM_PROVIDER=gemini
# LLM_MODEL=                    # Override single-message model (optional)
# LLM_MODEL_THREAD=             # Override thread analysis model (optional)
OPENAI_API_KEY=
GEMINI_API_KEY=your_gemini_api_key_here

# LLM Gating Thresholds
LLM_MSG_THRESHOLD=20             # Messages before auto-triggering LLM
LLM_TIME_THRESHOLD_MIN=10       # Minutes of inactivity before time-trigger
LLM_COOLDOWN_SEC=60             # Cooldown between automatic triggers
LLM_RISK_THRESHOLD=0.7          # Risk score threshold (0-1) for immediate trigger
LLM_DAILY_BUDGET_USD=10.00      # Daily LLM spend cap per workspace

# Embedding (optional — enables semantic context retrieval)
EMBEDDING_MODEL=text-embedding-3-small

# Context Assembly
CONTEXT_TOKEN_BUDGET=3500        # Token budget for context packs

# Rollup Thresholds
ROLLUP_MSG_THRESHOLD=20          # Messages before channel rollup
ROLLUP_TIME_THRESHOLD_MIN=10     # Minutes before time-based rollup
ROLLUP_THREAD_REPLY_THRESHOLD=10 # Thread replies before thread rollup

# Data Retention (days)
MESSAGE_RETENTION_DAYS=90
ANALYTICS_RETENTION_DAYS=180

# Privacy Filter
PRIVACY_MODE=redact               # off | redact | skip — controls sensitive content handling before LLM calls
