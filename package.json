{
  "name": "slack-sentiment-backend",
  "version": "1.0.0",
  "description": "Slack sentiment analysis backend",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:https": "tsx watch src/index.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node scripts/copy-migrations.mjs",
    "start": "node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "start:web": "RUNTIME_ROLE=web node dist/index.js",
    "start:worker": "RUNTIME_ROLE=worker node dist/index.js",
    "start:scheduler": "RUNTIME_ROLE=scheduler node dist/index.js",
    "start:prod:web": "NODE_ENV=production RUNTIME_ROLE=web node dist/index.js",
    "start:prod:worker": "NODE_ENV=production RUNTIME_ROLE=worker node dist/index.js",
    "start:prod:scheduler": "NODE_ENV=production RUNTIME_ROLE=scheduler node dist/index.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "eval:hybrid-triage": "tsx src/evals/hybridCrucialMomentsEval.ts",
    "migrate": "tsx src/db/migrate.ts",
    "prepare": "husky",
    "test:browser": "vitest --config=vitest.browser.config.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.98.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jose": "^6.2.0",
    "node-emoji": "^2.2.0",
    "openai": "^6.25.0",
    "pg": "^8.19.0",
    "pg-boss": "^12.14.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "bash -c 'tsc --noEmit'"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "@vitest/browser-preview": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "eslint-plugin-import-x": "^4.16.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
